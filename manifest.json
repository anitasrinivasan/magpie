{
  "manifest_version": 3,
  "name": "Magpie",
  "version": "1.0.0",
  "description": "Collect your shiny things — export saved posts from Twitter/X and LinkedIn",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/i/bookmarks*",
        "https://twitter.com/i/bookmarks*"
      ],
      "js": ["storage.js", "content-twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/my-items/saved-posts/*"
      ],
      "js": ["storage.js", "content-linkedin.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
